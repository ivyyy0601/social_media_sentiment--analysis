    "default_query": "stocks OR finance OR investing OR trading",
    "filter_patterns": {
      "exclude_titles": [
        "daily.*discussion",
        "general.*discussion",
        "advice.*thread",
        "what.*are.*your.*moves",
        "weekend.*discussion",
        "discussion.*thread",
        "daily.*thread"
      ],
      "exclude_keywords": [
        "which niche",
        "wanted to talk to but",
        "career advice",
        "networking",
        "should i",
        "how do i become",
        "resume",
        "job interview"
      ]
    }
  },
    "x": {
      "bearer_token": "PASTE_YOUR_X_BEARER_TOKEN",
      "default_query": "(AAPL OR MSFT OR GOOG OR AMZN OR NVDA OR TSLA OR META OR AVGO OR TXN OR COHR OR INTC OR ASML OR SNDK) lang:en -is:retweet",
      "json_page_limit": 100,
      "max_pages": 20,
      "sleep_sec": 0.8,
      "max_retries": 5
    },
  "sentiment": {
    "model": "ProsusAI/finbert",
    "confidence_threshold": 0.6
  },
